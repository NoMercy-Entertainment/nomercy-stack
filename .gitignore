.env
.idea
.vscode

# Local dev compose override — not for production
docker-compose.override.yml

# Database dumps and backups — never commit these
*.sql
*.sql.gz
*.sql.bz2
*.dump
*.bak

keycloak/themes/*
!keycloak/themes/.gitkeep
!keycloak/themes/NoMercy.V4/

postgres-kc/data/*
!postgres-kc/data/.gitkeep

mysql/data/*
!mysql/data/.gitkeep

portainer/data/*
!portainer/data/.gitkeep

postgres/data/*
!postgres/data/.gitkeep

proxy/certificates/*
!proxy/certificates/.gitkeep

proxy/sites/*
!proxy/sites/.gitkeep
!proxy/sites/*.conf
!proxy/sites/*.conf.default

# Blue-green upstream target is server-generated by scripts/deploy-website.sh
# on every deploy (see upstream-website.conf.default for the tracked
# template); never track its churn or let `git checkout -- .` reset it
# mid-rollout.
proxy/sites/upstream-website.conf

shares/*
!shares/.gitkeep

website/data/*
!website/data/public
website/data/public/*
!website/data/public/.gitkeep

# Blue-green "green" checkout + active-color marker are server-provisioned
# runtime state (scripts/deploy-website.sh), not tracked like the "data"
# submodule.
website/data-green/
website/.active-color
logs/fail2ban/fail2ban.log
logs/nginx/access.log
logs/nginx/debug.log
logs/nginx/error.log
logs/fail2ban/*
fail2ban/config/fail2ban/fail2ban.sqlite3
logs/logrotate.status
